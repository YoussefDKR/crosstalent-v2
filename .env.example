# App
# Production: https://www.crosstalent.io (www is canonical; apex redirects in middleware)
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Supabase (Phase 2+)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# RSS job sync (Vercel Cron + manual trigger)
CRON_SECRET=generate-a-long-random-string

# Stripe (Phase 8) — leave empty until you create a Stripe account
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs (from Dashboard → Products → each price)
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_SCALE=
